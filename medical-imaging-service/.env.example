# Service
APP_NAME=medical-imaging-service
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
PUBLIC_BASE_URL=https://api.example.com

# CORS (only used if the service is reached without the gateway)
CORS_ALLOWED_ORIGINS=https://app.example.com

# Database (audit + sync registry — Supabase Postgres works)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@imaging-db:5432/medimg
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT — must match the Auth Service signing config
JWT_SECRET_KEY=change-me-please-this-must-be-at-least-64-hex-chars
JWT_ALGORITHM=HS256
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=medical-imaging-platform

# DICOMweb provider — dynamic, can be reconfigured at runtime via admin endpoint
DICOMWEB_BASE_URL=https://orthanc.internal/dicom-web
DICOMWEB_AUTH_TYPE=basic        # one of: none, basic, bearer
DICOMWEB_USERNAME=orthanc
DICOMWEB_PASSWORD=orthanc
DICOMWEB_BEARER_TOKEN=
DICOMWEB_VERIFY_TLS=true
DICOMWEB_TIMEOUT_SECONDS=60

# Orthanc tunnel — informational; the actual tunnel runs outside this service
# (Tailscale, WireGuard, SSH tunnel, Cloudflare Tunnel, etc.)
ORTHANC_TUNNEL_KIND=wireguard

# Sync ingestion — Raspberry Pi devices upload encrypted .dicom files here
# AES-256-GCM key (base64). Generate: `openssl rand -base64 32`
SYNC_AES_KEY_BASE64=change-me-base64-32-bytes
# Optional HMAC key for body signing (base64). Generate: `openssl rand -base64 48`
SYNC_HMAC_KEY_BASE64=change-me-base64-48-bytes
# Max payload size (bytes) for a single sync upload
SYNC_MAX_UPLOAD_BYTES=1073741824

# Central storage for sync'd DICOM files
STORAGE_BACKEND=filesystem      # one of: filesystem, s3
STORAGE_ROOT=/data/dicom
# S3 — only consulted when STORAGE_BACKEND=s3
S3_ENDPOINT_URL=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
