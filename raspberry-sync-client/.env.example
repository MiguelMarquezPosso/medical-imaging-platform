# --- API ---
# Public HTTPS gateway
API_BASE_URL=https://api.example.com
API_VERIFY_TLS=true

# Sync device credentials (must exist in Auth Service with role `sync-device`)
SYNC_DEVICE_EMAIL=pi-ward3@example.com
SYNC_DEVICE_PASSWORD=device-password-replace-me
SYNC_DEVICE_ID=pi-ward3-001

# --- Crypto ---
# AES-256 key (base64). Must match medical-imaging-service SYNC_AES_KEY_BASE64.
SYNC_AES_KEY_BASE64=change-me-base64-32-bytes
# HMAC key (base64). Must match medical-imaging-service SYNC_HMAC_KEY_BASE64.
SYNC_HMAC_KEY_BASE64=

# --- File watcher ---
WATCH_DIR=/var/lib/medimg-sync/inbox
# Files matching this glob are considered ready to upload
WATCH_GLOB=*.dcm
# Where successfully uploaded files are moved (kept for forensics; rotate yourself)
ARCHIVE_DIR=/var/lib/medimg-sync/archive
# Failed uploads are moved here
QUARANTINE_DIR=/var/lib/medimg-sync/quarantine
# Pending DB (sqlite) — survives reboots and offline windows
STATE_DB=/var/lib/medimg-sync/state.sqlite3

# --- Networking ---
# Poll interval for the periodic retry loop (seconds)
RETRY_INTERVAL_SECONDS=30
# Time to wait before considering the internet "down" (seconds)
CONNECTIVITY_CHECK_INTERVAL=15
# Max parallel uploads
MAX_CONCURRENCY=2

LOG_LEVEL=INFO
