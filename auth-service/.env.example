# Service
APP_NAME=auth-service
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Public base URL used to mint absolute URLs
PUBLIC_BASE_URL=https://api.example.com

# CORS — comma separated list of allowed origins (only consulted when not behind the gateway)
CORS_ALLOWED_ORIGINS=https://app.example.com

# Database — Supabase Postgres connection string
# Use the connection pooler URL provided by Supabase for async drivers
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/auth
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# JWT
# Generate strong values: `openssl rand -hex 64`
JWT_SECRET_KEY=change-me-please-this-must-be-at-least-64-hex-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
JWT_ISSUER=https://api.example.com
JWT_AUDIENCE=medical-imaging-platform

# Password policy
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true

# Registration
ALLOW_PUBLIC_REGISTRATION=false
DEFAULT_USER_ROLE=viewer
