# API Gateway environment

# Public domain served over HTTPS
GATEWAY_DOMAIN=api.example.com

# Upstream internal services (resolved on the docker network `medimg-internal`)
AUTH_SERVICE_UPSTREAM=auth-service:8000
MEDICAL_IMAGING_UPSTREAM=medical-imaging-service:8000

# CORS allowed origins (comma separated)
CORS_ALLOWED_ORIGINS=https://app.example.com

# TLS contact email for Let's Encrypt
TLS_CONTACT_EMAIL=ops@example.com

# Timezone
TZ=UTC

# Rate limiting (req/s per client IP)
RATE_LIMIT_AUTH_RPS=5
RATE_LIMIT_API_RPS=30
RATE_LIMIT_SYNC_RPS=10
